---
import { ClientRouter } from 'astro:transitions';
import Search from '../components/Search.astro';
import Sidebar from '../components/Sidebar.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
	title?: string;
	description?: string;
}

const { title = "Digital Garden", description = "A growing collection of notes and ideas" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
		<ClientRouter />
		<script is:inline>
			// Apply sidebar and theme state immediately before render
			(function() {
				// Theme
				const savedTheme = localStorage.getItem('theme');
				const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
					document.documentElement.classList.add('dark');
				}

				// Sidebar
				const savedState = localStorage.getItem('sidebar-collapsed');
				const isDesktop = window.innerWidth >= 1024;
				
				if (isDesktop && savedState !== 'true') {
					document.documentElement.classList.add('sidebar-open');
				}
			})();

			// Handle sidebar state during view transitions
			document.addEventListener('astro:before-swap', (event) => {
				// Reset scroll lock
				document.body.style.overflow = '';

				const sidebar = event.newDocument.getElementById('sidebar');
				if (!sidebar) return;
				
				const savedState = localStorage.getItem('sidebar-collapsed');
				const isDesktop = window.innerWidth >= 1024;
				
				if (isDesktop && savedState !== 'true') {
					sidebar.classList.remove('sidebar-hidden');
					event.newDocument.documentElement.classList.add('sidebar-open');
				} else {
					sidebar.classList.add('sidebar-hidden');
				}
			});
		</script>
	</head>
	<body class="min-h-screen transition-colors duration-300">
		<Search />

		<!-- Mobile Header -->
		<header class="lg:hidden bg-[var(--color-surface-floating)] dark:bg-[var(--color-surface-base)] border-b border-[var(--color-border-subtle)] dark:border-[var(--color-border-subtle)] sticky top-0 z-40">
			<nav class="max-w-4xl mx-auto px-4 h-16 flex items-center justify-between">
				<div class="flex items-center gap-3">
					<button
						id="sidebar-toggle-mobile"
						class="p-1.5 rounded-lg bg-[var(--color-surface-elevated)] dark:bg-[var(--color-surface-floating)] hover:bg-[var(--color-surface-elevated)] dark:hover:bg-[var(--color-surface-floating)] text-[var(--color-accent)] dark:text-[var(--color-accent)] border border-[var(--color-accent-teal)]/20 dark:border-[var(--color-accent-teal-light)]/20 transition-colors"
						aria-label="Toggle sidebar"
					>
						<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<line x1="3" y1="12" x2="21" y2="12"></line>
							<line x1="3" y1="6" x2="21" y2="6"></line>
							<line x1="3" y1="18" x2="21" y2="18"></line>
						</svg>
					</button>
					<a href="/" class="text-xl font-bold text-[var(--color-text-heading)] dark:text-[var(--color-text-heading)] hover:text-[var(--color-accent)] dark:hover:text-[var(--color-accent)] transition-all">
						<span class="text-[var(--color-accent)]">❯</span> Garden
					</a>
				</div>
				<div class="flex items-center gap-2">
					<ThemeToggle />
					<button id="search-trigger-mobile" class="flex items-center gap-2 px-4 py-2 bg-[var(--color-surface-elevated)] dark:bg-[var(--color-surface-floating)] rounded-lg hover:bg-[var(--color-surface-elevated)] dark:hover:bg-[var(--color-surface-floating)] transition-all text-sm text-[var(--color-text-body)] dark:text-[var(--color-text-muted)] hover:text-[var(--color-accent)] dark:hover:text-[var(--color-accent)]" aria-label="Search notes">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="11" cy="11" r="8"></circle>
							<path d="m21 21-4.3-4.3"></path>
						</svg>
						<span class="hidden sm:inline">Search</span>
					</button>
				</div>
			</nav>
		</header>

		<!-- Desktop Header - full width -->
		<header class="hidden lg:block w-full bg-[var(--color-surface-floating)] dark:bg-[var(--color-surface-base)] border-b border-[var(--color-border-subtle)] dark:border-[var(--color-border-subtle)] sticky top-0 z-40">
			<nav class="h-16 flex items-center gap-4 px-4">
				<button
					id="sidebar-toggle"
					class="p-1.5 rounded-lg bg-[var(--color-surface-elevated)] dark:bg-[var(--color-surface-floating)] hover:bg-[var(--color-surface-elevated)] dark:hover:bg-[var(--color-surface-floating)] text-[var(--color-accent)] dark:text-[var(--color-accent)] hover:text-[var(--color-accent-teal-dark)] dark:hover:text-[var(--color-accent)] border border-[var(--color-accent-teal)]/20 dark:border-[var(--color-accent-teal-light)]/20 hover:border-[var(--color-accent-teal)]/40 dark:hover:border-[var(--color-accent-teal-light)]/40 transition-colors"
					aria-label="Toggle sidebar"
					title="Toggle sidebar"
				>
					<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
						<line x1="9" y1="3" x2="9" y2="21"></line>
					</svg>
				</button>
				<div class="flex-1 flex justify-center max-w-2xl mx-auto w-full">
					<button id="search-trigger-desktop" class="flex items-center gap-3 px-6 py-2.5 bg-[var(--color-surface-elevated)] dark:bg-[var(--color-surface-floating)] rounded-lg hover:bg-[var(--color-surface-elevated)] dark:hover:bg-[var(--color-surface-floating)] transition-all text-sm text-[var(--color-text-body)] dark:text-[var(--color-text-muted)] hover:text-[var(--color-accent)] dark:hover:text-[var(--color-accent)] w-full border border-[var(--color-accent-teal)]/20 dark:border-[var(--color-accent-teal-light)]/20 hover:border-[var(--color-accent-teal)]/40 dark:hover:border-[var(--color-accent-teal-light)]/40" aria-label="Search notes">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="11" cy="11" r="8"></circle>
							<path d="m21 21-4.3-4.3"></path>
						</svg>
						<span class="flex-1 text-left">Search notes...</span>
						<kbd class="hidden sm:inline px-1.5 py-0.5 text-xs bg-[var(--color-surface-elevated)] dark:bg-[var(--color-surface-floating)] text-[var(--color-text-muted)] dark:text-[var(--color-text-placeholder)] rounded">⌘K</kbd>
					</button>
				</div>
				<ThemeToggle />
			</nav>
		</header>

		<div class="lg:flex min-h-screen" id="main-container">
			<Sidebar />
			
			<div class="flex-1 flex flex-col min-w-0" id="main-content">
				<main class="flex-1 w-full mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12 lg:max-w-4xl xl:max-w-5xl">
					<slot />
				</main>
				
				<footer class="border-t border-[var(--color-border-subtle)] dark:border-[var(--color-border-subtle)] mt-auto">
					<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
						<p class="text-center text-[var(--color-text-muted)] dark:text-[var(--color-text-placeholder)] text-sm">
							<span class="text-[var(--color-accent)]">❯</span> Grown with care <span class="text-[var(--color-accent-coral)]">•</span> Built with Astro & Obsidian
						</p>
					</div>
				</footer>
			</div>
		</div>

		<script>
			(function() {
				const STORAGE_KEY = 'sidebar-collapsed';
				const LG_BREAKPOINT = 1024;

				function isMobile() {
					return window.innerWidth < LG_BREAKPOINT;
				}

				function loadState() {
					try {
						return localStorage.getItem(STORAGE_KEY) === 'true';
					} catch (e) {
						return false;
					}
				}

				function saveState(collapsed: boolean) {
					try {
						localStorage.setItem(STORAGE_KEY, collapsed.toString());
					} catch (e) {}
				}

				function updateSidebar() {
					const SIDEBAR = document.getElementById('sidebar');
					const BACKDROP = document.getElementById('sidebar-backdrop');
					if (!SIDEBAR) return;
					
					const collapsed = loadState();
					if (isMobile()) {
						SIDEBAR.classList.add('sidebar-hidden');
						if (BACKDROP) BACKDROP.classList.add('hidden');
						document.body.style.overflow = '';
					} else if (collapsed) {
						SIDEBAR.classList.add('sidebar-hidden');
						if (BACKDROP) BACKDROP.classList.add('hidden');
						document.body.style.overflow = '';
					} else {
						SIDEBAR.classList.remove('sidebar-hidden');
						if (BACKDROP) BACKDROP.classList.add('hidden'); // Desktop doesn't show backdrop
						document.body.style.overflow = '';
					}
					
					// Remove initial flash prevention class
					document.documentElement.classList.remove('sidebar-open');
				}

				function initSidebar() {
					document.addEventListener('click', function(e) {
						const toggleDesktop = document.getElementById('sidebar-toggle');
						const toggleMobile = document.getElementById('sidebar-toggle-mobile');
						const closeMobile = document.getElementById('sidebar-close-mobile');
						const sidebar = document.getElementById('sidebar');
						const backdrop = document.getElementById('sidebar-backdrop');
						
						const target = e.target as Node;
						
						// Handle Backdrop or Close Button Click
						const isCloseMobile = closeMobile && (target === closeMobile || closeMobile.contains(target));
						if ((backdrop && (target === backdrop || backdrop.contains(target))) || isCloseMobile) {
							if (!sidebar) return;
							sidebar.classList.add('sidebar-hidden');
							if (backdrop) backdrop.classList.add('hidden');
							document.body.style.overflow = '';
							return; // Don't save state for mobile dismiss
						}

						// Handle Toggle Click
						const isToggleDesktop = toggleDesktop && (target === toggleDesktop || toggleDesktop.contains(target));
						const isToggleMobile = toggleMobile && (target === toggleMobile || toggleMobile.contains(target));

						if (isToggleDesktop || isToggleMobile) {
							if (!sidebar) return;
							const isHidden = sidebar.classList.contains('sidebar-hidden');
							
							if (isHidden) {
								sidebar.classList.remove('sidebar-hidden');
								if (isMobile() && backdrop) {
									backdrop.classList.remove('hidden');
									document.body.style.overflow = 'hidden';
								}
							} else {
								sidebar.classList.add('sidebar-hidden');
								if (backdrop) backdrop.classList.add('hidden');
								document.body.style.overflow = '';
							}
							
							// Only save state on desktop
							if (!isMobile()) {
								saveState(!isHidden);
							}
						}
					});
				}

				// Run on initial page load
				initSidebar();

				// Re-run after each view transition (just update display, don't re-attach listeners)
				document.addEventListener('astro:page-load', updateSidebar);

				// Handle resize
				window.addEventListener('resize', updateSidebar);
			})();
		</script>

	<script is:inline>
		// Prevent dark mode flash during view transitions
		document.addEventListener('astro:before-swap', (event) => {
			const savedTheme = localStorage.getItem('theme');
			const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
			
			if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
				event.newDocument.documentElement.classList.add('dark');
			} else {
				event.newDocument.documentElement.classList.remove('dark');
			}
		});
	</script>
</body>
</html>

<style>
	@import '../styles/global.css';
</style>

<style is:global>
	/* Sidebar slide animation */
	.sidebar {
		transition: width 0.3s ease-in-out, transform 0.3s ease-in-out, opacity 0.3s ease-in-out, visibility 0.3s ease-in-out;
		overflow: hidden;
		white-space: nowrap;
	}

	.sidebar-hidden {
		width: 0 !important;
		opacity: 0;
		visibility: hidden;
		transform: translateX(-100%);
	}

	html.sidebar-open .sidebar-hidden {
		width: 18rem !important; /* w-72 */
		opacity: 1;
		visibility: visible;
		transform: translateX(0);
	}

	/* Main content margin transition */
	#main-content {
		transition: margin-left 0.3s ease-in-out;
	}

	.astro-code {
		background-color: var(--shiki-light-bg) !important;
	}

	.astro-code,
	.astro-code span {
		color: var(--shiki-light) !important;
	}

	html.dark .astro-code {
		background-color: var(--shiki-dark-bg) !important;
	}

	html.dark .astro-code,
	html.dark .astro-code span {
		color: var(--shiki-dark) !important;
	}

	html.dark .astro-code {
		border: 1px solid var(--color-border-subtle);
		box-shadow: 0 0 20px rgba(42, 157, 143, 0.1);
	}
</style>
