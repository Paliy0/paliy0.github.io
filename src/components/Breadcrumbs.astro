---
import type { CollectionEntry } from 'astro:content';

export interface BreadcrumbItem {
  label: string;
  href?: string;
}

export interface Props {
  items: BreadcrumbItem[];
  homeHref?: string;
  class?: string;
}

const { 
  items, 
  homeHref = '/',
  class: className = '' 
} = Astro.props;

export function generateNoteBreadcrumbs(
  note: CollectionEntry<'notes'>
): BreadcrumbItem[] {
  const breadcrumbs: BreadcrumbItem[] = [];
  const notePath = note.id;
  const pathParts = notePath.split('/');
  
  if (pathParts.length > 1) {
    let currentPath = '';
    for (let i = 0; i < pathParts.length - 1; i++) {
      currentPath = currentPath ? `${currentPath}/${pathParts[i]}` : pathParts[i];
      breadcrumbs.push({
        label: pathParts[i].replace(/-/g, ' '),
        href: `/${currentPath}`,
      });
    }
  }
  
  breadcrumbs.push({
    label: note.data.title,
  });
  
  return breadcrumbs;
}

export function generateTagBreadcrumbs(tag: string): BreadcrumbItem[] {
  return [
    { label: 'Tags', href: '/tags' },
    { label: tag },
  ];
}

export function generateFolderBreadcrumbs(folder: string): BreadcrumbItem[] {
  const parts = folder.split('/');
  const breadcrumbs: BreadcrumbItem[] = [];
  
  let currentPath = '';
  for (let i = 0; i < parts.length; i++) {
    currentPath = currentPath ? `${currentPath}/${parts[i]}` : parts[i];
    
    if (i === parts.length - 1) {
      breadcrumbs.push({
        label: parts[i].replace(/-/g, ' '),
      });
    } else {
      breadcrumbs.push({
        label: parts[i].replace(/-/g, ' '),
        href: `/${currentPath}`,
      });
    }
  }

  return breadcrumbs;
}
---

<nav class:list={["text-sm", className]} aria-label="Breadcrumb">
  <div class="flex items-center flex-wrap gap-1">
    <a 
      href={homeHref} 
      class="inline-flex items-center text-[var(--color-text-body)] dark:text-[var(--color-text-muted)] hover:text-[var(--color-accent)] dark:hover:text-[var(--color-accent)] transition-colors"
      aria-label="Home"
    >
      <svg class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor">
        <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z" />
      </svg>
    </a>
    
    {items.map((item) => (
      <span class="flex items-center gap-1">
        <svg 
          class="w-3.5 h-3.5 text-[var(--color-text-placeholder)] dark:text-[var(--color-text-muted)]" 
          viewBox="0 0 20 20" 
          fill="currentColor"
        >
          <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
        </svg>
        
        {item.href ? (
          <a 
            href={item.href} 
            class="text-[var(--color-text-body)] dark:text-[var(--color-text-muted)] hover:text-[var(--color-accent)] dark:hover:text-[var(--color-accent)] transition-colors truncate capitalize max-w-[150px] sm:max-w-[200px]"
            title={item.label}
          >
            {item.label}
          </a>
        ) : (
          <span 
            class="text-[var(--color-text-heading)] dark:text-[var(--color-text-body)] font-medium truncate capitalize max-w-[250px]"
            aria-current="page"
            title={item.label}
          >
            {item.label}
          </span>
        )}
      </span>
    ))}
  </div>
</nav>
