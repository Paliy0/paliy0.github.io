                        {child.notes.length > 0 && (
                          <div class="folder-children" data-parent-path={child.path}>
                            {child.notes.map((note: any) => (
                              <a
                                href={`/${note.slug}`}
                                class:list={[
                                  "sidebar-note-link flex items-center gap-3 rounded-lg transition-colors py-2 pl-4 pr-3 no-underline hover:no-underline",
                                  activeNoteSlug === note.slug
                                    ? "bg-[var(--color-surface-elevated)] dark:bg-[var(--color-surface-floating)] text-[var(--color-accent)] dark:text-[var(--color-accent)]"
                                    : "text-[var(--color-text-muted)] dark:text-[var(--color-text-placeholder)] hover:bg-[var(--color-surface-elevated)] dark:hover:bg-[var(--color-surface-floating)] hover:text-[var(--color-text-body)] dark:hover:text-[var(--color-text-body)]"
                                ]}
                                style={`padding-left: ${(child.level + 1) * 16 + 12}px;`}
                              >
                                <svg class="w-4 h-4 text-[var(--color-text-placeholder)] dark:text-[var(--color-text-muted)] shrink-0" viewBox="0 0 20 20" fill="currentColor">
                                  <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd" />
                                </svg>
                                <span class="flex-1 min-w-0 text-sm truncate">{note.title}</span>
                              </a>
                            ))}
                          </div>
                        )}
                      </div>
                    )}
                  </div>
                ))}
                
                {folder.notes.length > 0 && (
                  <div class="folder-children" data-parent-path={folder.path}>
                    {folder.notes.map((note: any) => (
                      <a
                        href={`/${note.slug}`}
                        class:list={[
                          "sidebar-note-link flex items-center gap-3 rounded-lg transition-colors py-2 pl-4 pr-3 no-underline hover:no-underline",
                          activeNoteSlug === note.slug
                            ? "bg-[var(--color-surface-elevated)] dark:bg-[var(--color-surface-floating)] text-[var(--color-accent)] dark:text-[var(--color-accent)]"
                            : "text-[var(--color-text-muted)] dark:text-[var(--color-text-placeholder)] hover:bg-[var(--color-surface-elevated)] dark:hover:bg-[var(--color-surface-floating)] hover:text-[var(--color-text-body)] dark:hover:text-[var(--color-text-body)]"
                        ]}
                        style={`padding-left: ${(folder.level + 1) * 16 + 12}px;`}
                      >
                        <svg class="w-4 h-4 text-[var(--color-text-placeholder)] dark:text-[var(--color-text-muted)] shrink-0" viewBox="0 0 20 20" fill="currentColor">
                          <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd" />
                        </svg>
                        <span class="flex-1 min-w-0 text-sm truncate">{note.title}</span>
                      </a>
                    ))}
                  </div>
                )}
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  )}
</aside>

<script>
  const STORAGE_KEY = 'sidebar-expanded-folders';

  function loadExpandedState(): Set<string> {
    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved) {
        return new Set(JSON.parse(saved));
      }
    } catch (e) {
      console.error('Failed to load sidebar state:', e);
    }
    return new Set();
  }

  function saveExpandedState(expanded: Set<string>) {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify([...expanded]));
    } catch (e) {
      console.error('Failed to save sidebar state:', e);
    }
  }

  function updateFolderIcon(folderNode: Element, isExpanded: boolean) {
    const closedIcon = folderNode.querySelector('.folder-icon-closed');
    const openIcon = folderNode.querySelector('.folder-icon-open');
    
    if (closedIcon && openIcon) {
      if (isExpanded) {
        closedIcon.classList.add('hidden');
        openIcon.classList.remove('hidden');
      } else {
        closedIcon.classList.remove('hidden');
        openIcon.classList.add('hidden');
      }
    }
  }

  function applyExpandedState(expanded: Set<string>) {
    document.querySelectorAll('.folder-node[data-has-children="true"]').forEach((node) => {
      const path = node.getAttribute('data-path');
      const children = node.querySelector('.folder-children');
      
      if (path && children) {
        const isExpanded = expanded.has(path);
        if (isExpanded) {
          children.classList.remove('hidden');
        } else {
          children.classList.add('hidden');
        }
        updateFolderIcon(node, isExpanded);
      }
    });

    updateToggleButtonIcon(expanded);
  }

  function updateToggleButtonIcon(expanded: Set<string>) {
    const expandIcon = document.getElementById('expand-icon');
    const collapseIcon = document.getElementById('collapse-icon');
    const toggleButton = document.getElementById('sidebar-toggle-all');
    const totalFolders = document.querySelectorAll('.folder-node[data-has-children="true"]').length;

    if (expandIcon && collapseIcon && toggleButton) {
      const isAllExpanded = expanded.size >= totalFolders && totalFolders > 0;
      if (isAllExpanded) {
        expandIcon.classList.add('hidden');
        collapseIcon.classList.remove('hidden');
        toggleButton.setAttribute('title', 'Collapse all folders');
        toggleButton.setAttribute('aria-label', 'Collapse all folders');
      } else {
        expandIcon.classList.remove('hidden');
        collapseIcon.classList.add('hidden');
        toggleButton.setAttribute('title', 'Expand all folders');
        toggleButton.setAttribute('aria-label', 'Expand all folders');
      }
    }
  }

  function initFolderTree() {
    const expandedFolders = loadExpandedState();
    const sidebar = document.getElementById('sidebar');
    const activePath = sidebar?.getAttribute('data-active-path');

    if (activePath && expandedFolders.size === 0) {
      const parts = activePath.split('/');
      let buildPath = '';
      for (const part of parts) {
        buildPath = buildPath ? `${buildPath}/${part}` : part;
        expandedFolders.add(buildPath);
      }
      saveExpandedState(expandedFolders);
    }

    applyExpandedState(expandedFolders);

    // Attach click handlers to folder rows
    document.querySelectorAll('.folder-row').forEach((row) => {
      row.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('.folder-link')) {
          return;
        }

        const folderPath = row.getAttribute('data-folder-path');
        const folderNode = row.closest('.folder-node');
        const children = folderNode?.querySelector('.folder-children');

        if (folderPath && children && folderNode) {
          const isHidden = children.classList.contains('hidden');
          const expanded = loadExpandedState();

          if (isHidden) {
            children.classList.remove('hidden');
            expanded.add(folderPath);
            updateFolderIcon(folderNode, true);
          } else {
            children.classList.add('hidden');
            expanded.delete(folderPath);
            updateFolderIcon(folderNode, false);
          }

          saveExpandedState(expanded);
          updateToggleButtonIcon(expanded);
        }
      });
    });

    // Attach click handler to toggle all button
    document.getElementById('sidebar-toggle-all')?.addEventListener('click', () => {
      const allFolders = document.querySelectorAll('.folder-node[data-has-children="true"]');
      const expanded = loadExpandedState();
      const totalFolders = allFolders.length;
      const isAllExpanded = expanded.size >= totalFolders;

      if (isAllExpanded) {
        expanded.clear();
        allFolders.forEach((node) => {
          const children = node.querySelector('.folder-children');
          if (children) {
            children.classList.add('hidden');
          }
          updateFolderIcon(node, false);
        });
      } else {
        allFolders.forEach((node) => {
          const path = node.getAttribute('data-path');
          const children = node.querySelector('.folder-children');
          if (path && children) {
            children.classList.remove('hidden');
            expanded.add(path);
          }
          updateFolderIcon(node, true);
        });
      }

      saveExpandedState(expanded);
      updateToggleButtonIcon(expanded);
    });
  }

  // Re-run after each view transition (also fires on initial load)
  document.addEventListener('astro:page-load', initFolderTree);
</script>
