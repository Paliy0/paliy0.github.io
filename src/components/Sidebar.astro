---
import { getCollection } from 'astro:content';

interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;

const notes = await getCollection('notes', (entry) => !entry.data.draft);

interface FolderNode {
  name: string;
  path: string;
  children: Map<string, FolderNode>;
  notes: { id: string; title: string; slug: string }[];
}

const rootFolders = new Map<string, FolderNode>();
const folderNotes = new Map<string, { id: string; title: string; slug: string }[]>();

notes.forEach((note) => {
  const parts = note.id.split('/');
  const fileName = parts.pop() || '';
  const folderPath = parts.join('/');
  
  const noteInfo = {
    id: note.id,
    title: note.data.title || fileName.replace(/\.md$/, ''),
    slug: note.id.replace(/\.md$/, '')
  };
  
  if (!folderNotes.has(folderPath)) {
    folderNotes.set(folderPath, []);
  }
  folderNotes.get(folderPath)!.push(noteInfo);
  
  if (parts.length === 0) return;
  
  let currentLevel = rootFolders;
  let currentPath = '';
  
  for (let i = 0; i < parts.length; i++) {
    const part = parts[i];
    currentPath = currentPath ? `${currentPath}/${part}` : part;
    
    if (!currentLevel.has(part)) {
      currentLevel.set(part, {
        name: part,
        path: currentPath,
        children: new Map(),
        notes: folderNotes.get(currentPath) || []
      });
    }
    
    currentLevel = currentLevel.get(part)!.children;
  }
});

function sortFolders(folders: Map<string, FolderNode>): Map<string, FolderNode> {
  const sorted = new Map([...folders.entries()].sort((a, b) => a[0].localeCompare(b[0])));
  sorted.forEach((folder) => {
    folder.children = sortFolders(folder.children);
    folder.notes.sort((a, b) => a.title.localeCompare(b.title));
  });
  return sorted;
}

const sortedRootFolders = sortFolders(rootFolders);

const activeFolderPath = currentPath.length > 1
  ? currentPath.replace(/^\//, '')
  : '';

const activeNoteSlug = currentPath.length > 1
  ? currentPath.replace(/^\//, '')
  : '';

function folderToArray(folder: FolderNode, level: number): any {
  return {
    name: folder.name,
    path: folder.path,
    level,
    isActive: activeFolderPath === folder.path,
    isOpen: activeFolderPath.startsWith(folder.path),
    hasChildren: folder.children.size > 0 || folder.notes.length > 0,
    notes: folder.notes,
    children: Array.from(folder.children.values()).map(child => folderToArray(child, level + 1))
  };
}

const folderTree = Array.from(sortedRootFolders.values()).map(folder => folderToArray(folder, 0));
---

<div id="sidebar-backdrop" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-40 hidden lg:hidden transition-opacity"></div>

<aside 
  id="sidebar" 
  class="sidebar sidebar-hidden fixed lg:sticky top-0 left-0 z-50 lg:z-0 w-72 h-screen overflow-y-auto border-r border-[var(--color-border-subtle)] dark:border-[var(--color-border-subtle)] bg-[var(--color-surface-floating)] dark:bg-[var(--color-surface-base)] p-4 shadow-2xl lg:shadow-none"
  data-active-path={activeFolderPath}
  data-active-note={activeNoteSlug}
>
  <div class="flex items-center justify-between mb-4">
    <a href="/" class="flex items-center gap-2 text-lg font-bold text-[var(--color-accent)] dark:text-[var(--color-accent)] hover:opacity-80 transition-all no-underline">
      <span>❯</span> Garden
    </a>
    <button
      id="sidebar-close-mobile"
      class="lg:hidden p-1.5 rounded-lg bg-[var(--color-surface-elevated)] dark:bg-[var(--color-surface-floating)] hover:bg-[var(--color-surface-elevated)] dark:hover:bg-[var(--color-surface-floating)] text-[var(--color-text-muted)] dark:text-[var(--color-text-placeholder)] hover:text-[var(--color-accent)] dark:hover:text-[var(--color-accent)] transition-colors"
      aria-label="Close sidebar"
    >
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>
  
  <nav class="space-y-0.5">
    <a 
      href="/" 
      class:list={[
        "flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors no-underline",
        currentPath === '/' 
          ? "bg-[var(--color-surface-elevated)] dark:bg-[var(--color-surface-floating)]" 
          : "opacity-70 hover:opacity-100 hover:bg-[var(--color-surface-elevated)] dark:hover:bg-[var(--color-surface-floating)]"
      ]}
    >
      <svg class="w-5 h-5 text-[var(--color-accent)]" viewBox="0 0 20 20" fill="currentColor">
        <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z" />
      </svg>
      <span class:list={["font-medium", currentPath === '/' ? "text-[var(--color-accent)]" : "text-[var(--color-text-body)] dark:text-[var(--color-text-muted)]"]}>Home</span>
    </a>
    
    <a 
      href="/notes" 
      class:list={[
        "flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors no-underline",
        currentPath === '/notes'
          ? "bg-[var(--color-surface-elevated)] dark:bg-[var(--color-surface-floating)]" 
          : "opacity-70 hover:opacity-100 hover:bg-[var(--color-surface-elevated)] dark:hover:bg-[var(--color-surface-floating)]"
