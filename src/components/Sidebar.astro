    >
      <svg class="w-5 h-5 text-[var(--color-accent)]" viewBox="0 0 20 20" fill="currentColor">
        <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" />
        <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 1 1 0 000 2H6v10h10v-2a1 1 0 112 0v2a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 011-1h6a1 1 0 110 2H8a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H8z" clip-rule="evenodd" />
      </svg>
      <span class:list={["font-medium", currentPath === '/notes' ? "text-[var(--color-accent)]" : "text-[var(--color-text-body)] dark:text-[var(--color-text-muted)]"]}>All Notes</span>
    </a>
    
    <a 
      href="/tags" 
      class:list={[
        "flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors no-underline",
        currentPath.startsWith('/tags')
