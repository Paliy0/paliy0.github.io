    </a>
  </nav>
  
  {folderTree.length > 0 && (
    <div class="mt-6 pt-6 border-t border-[var(--color-border-subtle)] dark:border-[var(--color-border-subtle)]">
      <div class="flex items-center justify-between mb-2 px-3">
        <h3 class="text-xs font-semibold text-[var(--color-text-muted)] dark:text-[var(--color-text-placeholder)] uppercase tracking-wider">
