                      </a>
                    </div>
                    
                    {child.hasChildren && (
                      <div 
                        class="folder-children overflow-hidden transition-all duration-200" 
                        data-parent-path={child.path}
                      >
                        {child.children.map((grandchild: any) => (
                          <div class="folder-node" data-path={grandchild.path} data-has-children={grandchild.hasChildren}>
                            <div 
                              class:list={[
                                "folder-row flex items-center gap-3 rounded-lg transition-colors group cursor-pointer select-none py-2",
                                grandchild.isActive 
                                  ? "bg-[var(--color-surface-elevated)] dark:bg-[var(--color-surface-floating)] text-[var(--color-accent)] dark:text-[var(--color-accent)]" 
                                  : "text-[var(--color-text-body)] dark:text-[var(--color-text-muted)] hover:bg-[var(--color-surface-elevated)] dark:hover:bg-[var(--color-surface-floating)]"
                              ]}
                              data-folder-path={grandchild.path}
                              style={`padding-left: ${grandchild.level * 16 + 12}px; padding-right: 12px;`}
                            >
                              {grandchild.hasChildren ? (
                                <div class="folder-toggle shrink-0">
                                  <svg class="folder-icon-closed w-5 h-5 text-[var(--color-accent)]" viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" />
                                  </svg>
                                  <svg class="folder-icon-open w-5 h-5 text-[var(--color-accent)] hidden" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M2 6a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1H8a3 3 0 00-3 3v1.5a1.5 1.5 0 01-3 0V6z" clip-rule="evenodd" />
                                    <path d="M6 12a2 2 0 012-2h8a2 2 0 012 2v2a2 2 0 01-2 2H2h2a2 2 0 002-2v-2z" />
                                  </svg>
                                </div>
                              ) : (
                                <svg class="w-5 h-5 text-[var(--color-accent)] shrink-0" viewBox="0 0 20 20" fill="currentColor">
                                  <path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" />
                                </svg>
                              )}
                              
                              <a
                                href={`/${grandchild.path}`}
                                class="folder-link flex-1 min-w-0 font-medium truncate capitalize text-inherit hover:text-inherit no-underline"
                                onclick="event.stopPropagation()"
                              >
                                {grandchild.name.replace(/-/g, ' ')}
                              </a>
                            </div>
                            
                            {grandchild.notes.length > 0 && (
                              <div class="folder-children" data-parent-path={grandchild.path}>
                                {grandchild.notes.map((note: any) => (
                                  <a
                                    href={`/${note.slug}`}
                                    class:list={[
                                      "sidebar-note-link flex items-center gap-3 rounded-lg transition-colors py-2 pl-4 pr-3 no-underline hover:no-underline",
                                      activeNoteSlug === note.slug
                                        ? "bg-[var(--color-surface-elevated)] dark:bg-[var(--color-surface-floating)] text-[var(--color-accent)] dark:text-[var(--color-accent)]"
                                        : "text-[var(--color-text-muted)] dark:text-[var(--color-text-muted)] hover:bg-[var(--color-surface-elevated)] dark:hover:bg-[var(--color-surface-floating)] hover:text-[var(--color-text-body)] dark:hover:text-[var(--color-text-body)]"
                                    ]}
                                    style={`padding-left: ${(grandchild.level + 1) * 16 + 12}px;`}
                                  >
                                    <svg class="w-4 h-4 text-[var(--color-text-placeholder)] dark:text-[var(--color-text-muted)] shrink-0" viewBox="0 0 20 20" fill="currentColor">
