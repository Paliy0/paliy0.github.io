---
---

<button
  data-theme-toggle
  class="group p-2.5 rounded-lg bg-[var(--color-surface-elevated)] dark:bg-[var(--color-surface-floating)] hover:bg-[var(--color-surface-elevated)] dark:hover:bg-[var(--color-surface-floating)] border border-[var(--color-accent-teal)]/20 dark:border-[var(--color-accent-teal-light)]/20 hover:border-[var(--color-accent-teal)]/40 dark:hover:border-[var(--color-accent-teal-light)]/40 transition-all"
  aria-label="Toggle dark mode"
  title="Toggle dark mode"
>
  <!-- Sun icon - shown in dark mode (click to switch to light) -->
  <svg data-sun-icon class="w-5 h-5 stroke-[var(--color-accent-teal-light)] dark:block hidden" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="5"/>
    <line x1="12" y1="1" x2="12" y2="3"/>
    <line x1="12" y1="21" x2="12" y2="23"/>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
    <line x1="1" y1="12" x2="3" y2="12"/>
    <line x1="21" y1="12" x2="23" y2="12"/>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
  </svg>
  <!-- Moon icon - shown in light mode (click to switch to dark) -->
  <svg data-moon-icon class="w-5 h-5 stroke-[var(--color-accent-teal)] dark:hidden" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<script is:inline>
  (function() {
    // Only initialize once
    if (window.__themeToggleInitialized) return;
    window.__themeToggleInitialized = true;

    function updateAllIcons() {
      const isDark = document.documentElement.classList.contains('dark');
      const sunIcons = document.querySelectorAll('[data-sun-icon]');
      const moonIcons = document.querySelectorAll('[data-moon-icon]');
      
      sunIcons.forEach(icon => {
        if (isDark) {
          icon.classList.remove('hidden');
        } else {
          icon.classList.add('hidden');
        }
      });
      
      moonIcons.forEach(icon => {
        if (isDark) {
          icon.classList.add('hidden');
        } else {
          icon.classList.remove('hidden');
        }
      });
    }

    // Wait for DOM to be ready before updating icons
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', updateAllIcons);
    } else {
      updateAllIcons();
    }

    // Handle all toggle buttons using event delegation
    document.addEventListener('click', (e) => {
      const toggle = e.target.closest('[data-theme-toggle]');
      if (!toggle) return;
      
      const isDark = document.documentElement.classList.contains('dark');
      const newTheme = isDark ? 'light' : 'dark';
      
      if (newTheme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
      
      localStorage.setItem('theme', newTheme);
      updateAllIcons();
    });

    // Listen for system theme changes
    const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
    mediaQuery.addEventListener('change', (e) => {
      // Only auto-switch if user hasn't manually set a preference
      if (!localStorage.getItem('theme')) {
        if (e.matches) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
        updateAllIcons();
      }
    });

    // Re-apply theme after view transitions (astro:after-swap)
    document.addEventListener('astro:after-swap', () => {
      updateAllIcons();
    });
  })();
</script>
