---
import { getCollection } from 'astro:content';
import { slugifyStr } from '../utils/slugify';

const notes = await getCollection('notes', ({ data }) => !data.draft);

const searchIndex = notes.map(note => ({
  slug: note.id.replace(/\.md$/, ''),
  title: note.data.title,
  description: note.data.description || '',
  content: note.body || '',
  tags: note.data.tags || [],
  transitionName: slugifyStr(note.data.title)
}));
---

<script is:inline define:vars={{ searchIndex }}>
  window.searchIndex = searchIndex;
</script>

<!-- Search Modal -->
<div
  id="search-modal"
  class="fixed inset-0 z-[60] pointer-events-none"
  role="dialog"
  aria-modal="true"
>
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm opacity-0 transition-opacity duration-300" id="search-backdrop"></div>
  
  <div id="search-dialog" class="absolute top-20 left-1/2 -translate-x-1/2 w-full max-w-2xl px-4 transition-all duration-300 scale-95 -translate-y-2 opacity-0">
    <div class="bg-[var(--color-surface-floating)] dark:bg-[var(--color-surface-base)] rounded-xl shadow-2xl overflow-hidden border border-[var(--color-border-subtle)] dark:border-[var(--color-border-subtle)]">
      <div class="flex items-center gap-3 px-4 py-3 border-b border-[var(--color-border-subtle)] dark:border-[var(--color-border-subtle)]">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-text-muted)] dark:text-[var(--color-text-placeholder)]">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <input 
          type="text" 
          id="search-input"
          placeholder="Search notes..."
          class="flex-1 bg-transparent outline-none text-[var(--color-text-heading)] dark:text-[var(--color-text-body)] placeholder-[var(--color-text-muted)] dark:placeholder-[var(--color-text-placeholder)]"
          autocomplete="off"
        >
        <kbd class="px-2 py-1 text-xs bg-[var(--color-surface-elevated)] dark:bg-[var(--color-surface-floating)] text-[var(--color-text-muted)] dark:text-[var(--color-text-placeholder)] rounded">ESC</kbd>
      </div>
      
      <div id="search-results" class="max-h-96 overflow-y-auto">
        <div class="p-8 text-center text-[var(--color-text-muted)] dark:text-[var(--color-text-placeholder)]">
          Type to search notes...
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import Fuse from 'fuse.js';
  
  let fuse;
  
  function getElements() {
    return {
      searchModal: document.getElementById('search-modal'),
      searchDialog: document.getElementById('search-dialog'),
      searchBackdrop: document.getElementById('search-backdrop'),
      searchInput: document.getElementById('search-input'),
      searchResults: document.getElementById('search-results'),
      searchTriggerMobile: document.getElementById('search-trigger-mobile'),
      searchTriggerDesktop: document.getElementById('search-trigger-desktop'),
    };
  }
  
  function initSearch() {
    if (!fuse && window.searchIndex) {
      fuse = new Fuse(window.searchIndex, {
        keys: ['title', 'description', 'content', 'tags'],
        threshold: 0.2,
        minMatchCharLength: 3,
        includeScore: true,
        includeMatches: true,
      });
    }
  }
  
  function openSearch() {
    initSearch();
    const { searchModal, searchBackdrop, searchDialog, searchInput } = getElements();

    if (searchModal && searchBackdrop && searchDialog) {
      searchModal.classList.remove('pointer-events-none');
      searchModal.classList.add('pointer-events-auto');

      requestAnimationFrame(() => {
        searchBackdrop.classList.remove('opacity-0');
        searchBackdrop.classList.add('opacity-100');

        searchDialog.classList.remove('scale-95', '-translate-y-2', 'opacity-0');
        searchDialog.classList.add('scale-100', 'translate-y-0', 'opacity-100');
      });
    }

    if (searchInput) {
      setTimeout(() => searchInput.focus(), 50);
    }
    document.body.style.overflow = 'hidden';
  }

  function closeSearch() {
    const { searchModal, searchBackdrop, searchDialog, searchInput, searchResults } = getElements();

    if (searchModal && searchBackdrop && searchDialog) {
      searchBackdrop.classList.remove('opacity-100');
      searchBackdrop.classList.add('opacity-0');

      searchDialog.classList.remove('scale-100', 'translate-y-0', 'opacity-100');
      searchDialog.classList.add('scale-95', '-translate-y-2', 'opacity-0');

      // Re-disable pointer events after transition completes
      setTimeout(() => {
        searchModal.classList.remove('pointer-events-auto');
        searchModal.classList.add('pointer-events-none');
      }, 300);
    }

    if (searchInput) {
      setTimeout(() => {
        (searchInput as HTMLInputElement).value = '';
        if (searchResults) {
          searchResults.innerHTML = '<div class="p-8 text-center text-[var(--color-text-muted)] dark:text-[var(--color-text-placeholder)]">Type to search notes...</div>';
        }
      }, 300);
    }
    document.body.style.overflow = '';
    selectedIndex = -1;
  }
  
  function escapeHtml(unsafe) {
    return (unsafe || '').replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
  }

  function highlightMatch(text, matches) {
    if (!matches || matches.length === 0) return escapeHtml(text);
    
    let result = '';
    let lastIndex = 0;
    const indices = matches[0].indices;
    
    // Sort indices ascending
    const sortedIndices = [...indices].sort((a, b) => a[0] - b[0]);
    
    for (const [start, end] of sortedIndices.slice(0, 3)) {
      if (start > lastIndex) {
        result += escapeHtml(text.slice(lastIndex, start));
      }
      result += '<mark class="bg-[var(--color-surface-elevated)] dark:bg-[var(--color-surface-floating)] text-[var(--color-accent)] dark:text-[var(--color-accent)]">' + escapeHtml(text.slice(start, end + 1)) + '</mark>';
      lastIndex = end + 1;
    }
    
    if (lastIndex < text.length) {
      result += escapeHtml(text.slice(lastIndex));
    }
    
    return result;
  }
  
  function renderResults(results) {
    const { searchResults } = getElements();
    if (!searchResults) return;
    
    if (results.length === 0) {
      searchResults.innerHTML = '<div class="p-8 text-center text-[var(--color-text-muted)] dark:text-[var(--color-text-placeholder)]">No results found</div>';
      return;
    }
    
    const html = results.slice(0, 10).map(result => {
      const note = result.item;
      const titleMatch = result.matches?.find(m => m.key === 'title');
      const descMatch = result.matches?.find(m => m.key === 'description');
      const contentMatch = result.matches?.find(m => m.key === 'content');
      
      const title = highlightMatch(note.title, titleMatch ? [titleMatch] : []);
      const description = note.description 
        ? highlightMatch(note.description.slice(0, 150), descMatch ? [descMatch] : [])
        : (contentMatch 
            ? '...' + highlightMatch(note.content.slice(contentMatch.indices[0][0], contentMatch.indices[0][0] + 100), [{...contentMatch, indices: [[0, 100]]}]) + '...'
            : escapeHtml(note.content.slice(0, 150)) + '...');
      
      return `
        <a href="/${note.slug}" class="block p-4 hover:bg-[var(--color-surface-elevated)] dark:hover:bg-[var(--color-surface-floating)] transition-colors border-b border-[var(--color-border-subtle)] dark:border-[var(--color-border-subtle)] last:border-0">
          <h3 class="font-semibold text-[var(--color-text-heading)] dark:text-[var(--color-text-body)] mb-1" style="view-transition-name: ${note.transitionName}">${title}</h3>
          <p class="text-sm text-[var(--color-text-body)] dark:text-[var(--color-text-muted)] line-clamp-2">${description}</p>
          ${note.tags.length > 0 ? `
            <div class="flex gap-2 mt-2">
              ${note.tags.slice(0, 3).map(tag => `<span class="text-xs text-[var(--color-text-muted)] dark:text-[var(--color-text-placeholder)]">#${escapeHtml(tag)}</span>`).join('')}
            </div>
          ` : ''}
        </a>
      `;
    }).join('');
    
    searchResults.innerHTML = html;
  }
  
  // Use event delegation for search triggers
  document.addEventListener('click', (e) => {
    const searchTriggerMobile = document.getElementById('search-trigger-mobile');
    const searchTriggerDesktop = document.getElementById('search-trigger-desktop');
    const searchBackdrop = document.getElementById('search-backdrop');
    
    // Check if click was on search trigger
    if ((searchTriggerMobile && (e.target === searchTriggerMobile || searchTriggerMobile.contains(e.target as Node))) ||
        (searchTriggerDesktop && (e.target === searchTriggerDesktop || searchTriggerDesktop.contains(e.target as Node)))) {
      e.preventDefault();
      openSearch();
    }
    
    // Check if click was on backdrop
    if (searchBackdrop && (e.target === searchBackdrop || searchBackdrop.contains(e.target as Node))) {
      closeSearch();
    }
  });
  
  // Input handler - re-attach after each view transition since input element is recreated
  function attachInputListener() {
    const searchInput = document.getElementById('search-input');
    
    // Remove any existing listener to prevent duplicates
    searchInput?.removeEventListener('input', handleInput);
    searchInput?.addEventListener('input', handleInput);
  }
  
  let selectedIndex = -1;

  function handleInput(e) {
    const query = e.target.value.trim();
    const searchResults = document.getElementById('search-results');
    selectedIndex = -1;
    if (!query) {
      if (searchResults) {
        searchResults.innerHTML = '<div class="p-8 text-center text-[var(--color-text-muted)] dark:text-[var(--color-text-placeholder)]">Type to search notes...</div>';
      }
      return;
    }
    
    if (fuse) {
      const results = fuse.search(query);
      renderResults(results);
    }
  }
  
  // Initial setup
  attachInputListener();
  
  // Re-attach input listener after each view transition
  document.addEventListener('astro:page-load', attachInputListener);
  
  // Global keyboard handler (doesn't need re-attaching)
  document.addEventListener('keydown', (e) => {
    // Cmd/Ctrl + K to open
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
      return;
    }
    
    const searchModal = document.getElementById('search-modal');
    if (!searchModal || searchModal.classList.contains('pointer-events-none')) return;

    // ESC to close
    if (e.key === 'Escape') {
      closeSearch();
      return;
    }

    const results = document.querySelectorAll('#search-results a');
    if (results.length === 0) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      selectedIndex = (selectedIndex + 1) % results.length;
      updateSelection(results);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      selectedIndex = selectedIndex - 1 < 0 ? results.length - 1 : selectedIndex - 1;
      updateSelection(results);
    } else if (e.key === 'Enter' && selectedIndex >= 0) {
      e.preventDefault();
      (results[selectedIndex] as HTMLAnchorElement).click();
    }
  });

  function updateSelection(results) {
    results.forEach((el, i) => {
      if (i === selectedIndex) {
        el.classList.add('bg-[var(--color-surface-elevated)]', 'dark:bg-[var(--color-surface-floating)]', 'border-l-4', 'border-[var(--color-accent)]', 'pl-3');
        el.classList.remove('pl-4'); // Adjust padding to compensate for border
        (el as HTMLElement).scrollIntoView({ block: 'nearest' });
      } else {
        el.classList.remove('bg-[var(--color-surface-elevated)]', 'dark:bg-[var(--color-surface-floating)]', 'border-l-4', 'border-[var(--color-accent)]', 'pl-3');
        el.classList.add('pl-4');
      }
    });
  }
</script>
